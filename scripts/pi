#!/usr/bin/env bash
#
# Containerized entry point for pi management. Delegates to the
# `pi-tools` service in docker-compose.yml (gated behind profile `tools`,
# so it never starts via plain `docker compose up`).
#
# Usage matches scripts/pi.sh exactly:
#   ./scripts/pi setup
#   ./scripts/pi deploy
#   ./scripts/pi watch
#   etc.
#
# If you'd rather run pi.sh directly on the host (e.g. you already have
# sshpass / rsync / python-build installed), invoke ./scripts/pi.sh
# instead.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${PROJECT_ROOT}"

if ! command -v docker >/dev/null 2>&1; then
    echo "ERROR: docker not found. Either install Docker Desktop or run scripts/pi.sh directly." >&2
    exit 1
fi

# Source .pi.env on the host so the values flow through compose's
# `environment:` block (which references $PI_HOST etc.). Without this,
# compose would only see vars that are already exported in the shell.
if [ -f "${PROJECT_ROOT}/.pi.env" ]; then
    set -a
    # shellcheck disable=SC1091
    source "${PROJECT_ROOT}/.pi.env"
    set +a
fi

# Rebuild the pi-tools image when the Dockerfile is newer than the
# cached image. Compose otherwise reuses whatever's tagged, so changes
# to docker/pi-tools.Dockerfile would silently go unbuilt.
IMAGE="ghostcam-pi-tools"
DOCKERFILE="${PROJECT_ROOT}/docker/pi-tools.Dockerfile"
need_build=0
if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
    need_build=1
else
    image_created=$(docker image inspect -f '{{.Created}}' "${IMAGE}" 2>/dev/null || echo "")
    if [ -n "${image_created}" ]; then
        image_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${image_created%.*Z}" "+%s" 2>/dev/null \
            || date -d "${image_created}" "+%s" 2>/dev/null || echo 0)
        dockerfile_epoch=$(stat -f "%m" "${DOCKERFILE}" 2>/dev/null \
            || stat -c "%Y" "${DOCKERFILE}" 2>/dev/null || echo 0)
        if [ "${dockerfile_epoch}" -gt "${image_epoch}" ]; then
            need_build=1
        fi
    fi
fi
if [ "${need_build}" -eq 1 ]; then
    echo "Building ${IMAGE} (first run / Dockerfile changed)..."
    docker compose build pi-tools >/dev/null
fi

# Profile-gated services aren't auto-started by `up`, but `run` bypasses
# profile filtering and starts the service one-shot. --rm cleans up the
# container after exit; compose handles TTY allocation automatically.
exec docker compose run --rm pi-tools "$@"
