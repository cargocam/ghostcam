#!/usr/bin/env bash
#
# Containerized entry point for pi management. Builds and runs the
# `pi-tools` image (docker/pi-tools.Dockerfile) directly via docker —
# no docker-compose needed, since this repo doesn't ship one.
#
# Usage matches scripts/pi.sh exactly:
#   ./scripts/pi setup
#   ./scripts/pi deploy
#   etc.
#
# If you'd rather run pi.sh directly on the host (e.g. you already have
# sshpass / rsync / Go installed), invoke ./scripts/pi.sh instead.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${PROJECT_ROOT}"

if ! command -v docker >/dev/null 2>&1; then
    echo "ERROR: docker not found. Either install Docker Desktop or run scripts/pi.sh directly." >&2
    exit 1
fi

# Source .pi.env on the host so values flow through `docker run -e`.
if [ -f "${PROJECT_ROOT}/.pi.env" ]; then
    set -a
    # shellcheck disable=SC1091
    source "${PROJECT_ROOT}/.pi.env"
    set +a
fi

# Rebuild the pi-tools image when the Dockerfile is newer than the
# cached image. Otherwise docker would silently reuse a stale layer.
IMAGE="ghostcam-pi-tools"
DOCKERFILE="${PROJECT_ROOT}/docker/pi-tools.Dockerfile"
need_build=0
if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
    need_build=1
else
    image_created=$(docker image inspect -f '{{.Created}}' "${IMAGE}" 2>/dev/null || echo "")
    if [ -n "${image_created}" ]; then
        image_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${image_created%.*Z}" "+%s" 2>/dev/null \
            || date -d "${image_created}" "+%s" 2>/dev/null || echo 0)
        dockerfile_epoch=$(stat -f "%m" "${DOCKERFILE}" 2>/dev/null \
            || stat -c "%Y" "${DOCKERFILE}" 2>/dev/null || echo 0)
        if [ "${dockerfile_epoch}" -gt "${image_epoch}" ]; then
            need_build=1
        fi
    fi
fi
if [ "${need_build}" -eq 1 ]; then
    echo "Building ${IMAGE} (first run / Dockerfile changed)..."
    docker build -t "${IMAGE}" -f "${DOCKERFILE}" "${PROJECT_ROOT}" >/dev/null
fi

exec docker run --rm -it \
    -e "PI_HOST=${PI_HOST:-}" \
    -e "PI_USER=${PI_USER:-}" \
    -e "PI_PASSWORD=${PI_PASSWORD:-}" \
    -e "GHOSTCAM_PUBLIC_IP=${GHOSTCAM_PUBLIC_IP:-}" \
    -v "${PROJECT_ROOT}:/repo" \
    "${IMAGE}" "$@"
