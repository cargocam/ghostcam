# infra/secrets.env — Copy to secrets.env and fill in values.
# Load into Pulumi with: ./load-secrets.sh
# This file is gitignored — never commit actual secrets.
#
# Fly.io auth: the Fly provider reads FLY_API_TOKEN from the environment.
# Set it before running pulumi: export FLY_API_TOKEN=$(flyctl auth token)

# Neon Postgres — get from https://console.neon.tech/ → API Keys
ghostcam-infra:neonApiKey=

# Stripe
ghostcam-infra:stripeSecretKey=sk_test_...

# Admin bootstrap
ghostcam-infra:adminEmail=admin@ghostcam.app
ghostcam-infra:adminPassword=

# Resend email — get from https://resend.com/api-keys
ghostcam-infra:resendApiKey=re_...

# Upstash Redis — run `flyctl redis create`, then `flyctl redis status <name>` to get the Private URL
# Leave empty if not using Redis (telemetry/SSE will be disabled)
ghostcam-infra:redisUrl=

# GitHub webhook
ghostcam-infra:githubWebhookSecret=

# Optional — leave blank to skip
ghostcam-infra:githubToken=
ghostcam-infra:anthropicApiKey=
ghostcam-infra:linearApiKey=
ghostcam-infra:linearTeamId=
