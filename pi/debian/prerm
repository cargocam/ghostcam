#!/bin/sh
# prerm — stop the service before unpacking the new version (upgrade)
# or removing the package. Leaves /var/ghostcam (identity key, data)
# in place; operators can re-install or purge as they choose.
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if [ -d /run/systemd/system ]; then
            systemctl stop ghostcam-camera.service >/dev/null 2>&1 || true
            systemctl stop ghostcam-gps.service >/dev/null 2>&1 || true
        fi
        ;;
esac

exit 0
