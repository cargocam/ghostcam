GHOSTCAM_DATA_DIR=/var/ghostcam
# Local offline provisioning server (USB gadget / SoftAP onboarding, #141).
# Binds only on the gadget link (usb0), never a routable interface. The
# gadget bring-up (ghostcam-usb-gadget.service) pins usb0 to 10.55.0.1.
GHOSTCAM_PROVISION_HTTP_ADDR=10.55.0.1:80
# UDC name override for the composite gadget; empty = auto-detect the
# single peripheral controller (correct on the Zero 2 W). Set explicitly
# on boards where auto-detect is wrong (CM4/CM5, #138).
GHOSTCAM_UDC=
