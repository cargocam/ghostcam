GHOSTCAM_DATA_DIR=/var/ghostcam
# Cellular APN for the fleet's SIMs (EIOTCLUB, BICS backbone). Baked into
# the image so a fresh flash brings up the cellular data bearer with no
# SSH / no server push — network.EnsureCellular provisions the gsm
# connection from this at boot. Override per-deployment if the SIM differs.
GHOSTCAM_CELLULAR_APN=america.bics
