# .env.example — Copy to .env and fill in values
# Only GHOSTCAM_PUBLIC_IP and STRIPE_SECRET_KEY are required for local dev.

# ── Required ─────────────────────────────────────────────────────────
# Your LAN IP (used for MinIO presigned URLs and WebRTC ICE candidates)
GHOSTCAM_PUBLIC_IP=            # e.g. 192.168.1.42  (run: ipconfig getifaddr en0)

# Stripe test-mode secret key (server refuses to start without this)
STRIPE_SECRET_KEY=sk_test_...

# ── Optional (local dev works without these) ─────────────────────────
# Stripe customer portal configuration ID
# STRIPE_PORTAL_CONFIG_ID=

# GitHub webhook HMAC secret (firmware image publishing)
# GITHUB_WEBHOOK_SECRET=
# GitHub token (private release asset downloads)
# GITHUB_TOKEN=

# Resend transactional email (omit = emails logged to stdout)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Ghostcam <noreply@example.com>
# RESEND_REPLY_TO=support@example.com

# Timezone for test cameras (default: America/Los_Angeles)
# TZ=America/Los_Angeles

# ── Self-hosted CI runner (docker compose --profile runner) ──────────
# Generate at repo Settings → Actions → Runners → New self-hosted runner
# GITHUB_RUNNER_TOKEN=

# ── Production only (not used by docker-compose) ────────────────────
# GHOSTCAM_DATABASE_URL=postgres://user:pass@host:5432/ghostcam
# GHOSTCAM_REDIS_URL=rediss://default:pass@host:6379
# GHOSTCAM_S3_BUCKET=ghostcam-segments
# GHOSTCAM_S3_REGION=auto
# GHOSTCAM_S3_ENDPOINT=https://fly.storage.tigris.dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# GHOSTCAM_PUBLIC_URL=https://ghostcam.example.com
# GHOSTCAM_ADMIN_EMAIL=admin@example.com
# GHOSTCAM_ADMIN_PASSWORD=          # auto-generated if omitted
# RESEND_WEBHOOK_SECRET=whsec_...
# ANTHROPIC_API_KEY=                 # support email triage (omit = raw fallback)
# LINEAR_API_KEY=                    # support ticket creation (omit = no-op)
# LINEAR_TEAM_ID=                    # required when LINEAR_API_KEY is set
