# LAN IP for WebRTC ICE candidates (required for Firefox)
# macOS: echo "GHOSTCAM_PUBLIC_IP=$(ipconfig getifaddr en0)" > .env
# Linux: echo "GHOSTCAM_PUBLIC_IP=$(hostname -I | awk '{print $1}')" > .env
GHOSTCAM_PUBLIC_IP=

# Stripe billing (optional — leave empty to disable billing)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICING_TABLE_ID=
STRIPE_PORTAL_CONFIG_ID=
