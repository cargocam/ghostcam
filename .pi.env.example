# Per-developer Pi connection settings consumed by `./scripts/pi.sh`.
# Copy this file to `.pi.env` (gitignored) and edit your local values.
#
#   cp .pi.env.example .pi.env
#   $EDITOR .pi.env

# Required. Your Pi's LAN IP or .local mDNS name.
# Find with: `arp -a | grep -i raspberry` or look at your router's DHCP table.
# Example: PI_HOST=192.168.1.42
PI_HOST=

# Optional. The Pi user `./scripts/pi.sh` SSHes as. Defaults to "ghostcam"
# which matches the user provisioned by the dev-image YAML (pi/image/config/
# ghostcam-*.yaml: user1=ghostcam).
# PI_USER=ghostcam

# Optional. Password for the dev image. Defaults to "Ghostcam1!" — the
# default password baked into the dev image. SSH is only reachable on
# images flashed via `./scripts/pi.sh flash-dev`; production images
# ship with sshd disabled, so this default is dev-only.
# PI_PASSWORD=Ghostcam1!

# Optional. When `./scripts/pi point-at local` resolves the dev-machine
# LAN IP, it first reads GHOSTCAM_PUBLIC_IP from `.env` in this repo.
# Set it here too if you're invoking pi.sh from outside docker-compose
# context (no .env at repo root).
# GHOSTCAM_PUBLIC_IP=192.168.1.5
